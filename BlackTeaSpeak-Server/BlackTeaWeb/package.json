{
  "name": "blackteaspeak-web",
  "version": "1.5.0",
  "description": "BlackTeaSpeak Web is the modern browser client maintained inside the BlackTeaSpeak workspace.",
  "scripts": {
    "compile-project-base": "tsgo -p tsbaseconfig.json",
    "compile-tr-gen": "tsgo -p tools/trgen/tsconfig.json",
    "trgen": "node tools/trgen/index.js",
    "tsc": "tsgo",
    "compile-scss": "sass loader/css/index.scss:loader/css/index.css",
    "start": "npm run compile-project-base && webpack serve --mode development --config webpack-web.config.js",
    "start-client": "npm run compile-project-base && webpack serve --mode development --config webpack-client.config.js",
    "build-web": "npm run compile-project-base && webpack --mode production --config webpack-web.config.js",
    "build-client": "npm run compile-project-base && webpack --mode production --config webpack-client.config.js",
    "generate-i18n-gtranslate": "node shared/generate_i18n_gtranslate.js"
  },
  "author": "BlackTeaSpeak",
  "license": "ISC",
